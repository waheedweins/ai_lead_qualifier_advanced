# Copy to .env for local development
# On AWS ECS these come from Secrets Manager automatically

DATABASE_URL=postgresql://postgres:password@localhost:5432/lead_engine

# Scrapers
APIFY_API_TOKEN=your_apify_token_here
APOLLO_API_KEY=your_apollo_key_here         # free at apollo.io

# AI
GEMINI_API_KEY=your_gemini_key_here         # free at aistudio.google.com
TAVILY_API_KEY=your_tavily_key_here         # free at tavily.com

# Outreach
SENDGRID_API_KEY=your_sendgrid_key_here
EMAIL_FROM=outreach@yourdomain.com
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_ID=your_phone_id_here
